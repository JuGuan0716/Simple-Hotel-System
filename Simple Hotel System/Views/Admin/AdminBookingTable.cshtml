@section Scripts {
    <script>
        $(document).ready(function () {
            loadBookingTable();
        });

        function loadBookingTable() {
            $('#bookingTable').DataTable({
                ajax: {
                    url: '/Booking/GetAllBookings',
                    type: 'GET',
                    dataSrc: 'data'
                },
                columns: [
                    { data: 'no' },
                    { data: 'id' },
                    { data: 'guestid' },
                    { data: 'roomid' },
                    { data: 'checkin' },
                    { data: 'checkout' },
                    { data: 'nights' },
                    { data: 'totalprice' },
                    {
                        data: null,
                        orderable: false,
                        render: function (data, type, row) {
                            return `
                                <a href="/Booking/BookingReceipt/${row.id}"
                                   class="btn btn-sm btn-info me-1">
                                   <i class="bi bi-eye"></i>
                                </a>

                                <a href="/Booking/PrintReceipt/${row.id}"
                                   target="_blank"
                                   class="btn btn-sm btn-secondary">
                                   <i class="bi bi-printer"></i>
                                </a>
                            `;
                        }
                    } 
                ]
            });
        }
    </script>
}