        <tr>
            <th>No</th>
            <th>Booking ID</th>
            <th>GuestId</th>
            <th>RoomId</th>
            <th>CheckIn</th>
            <th>CheckOut</th>
            <th>Nights</th>
            <th>Total Price</th>
            <th>Actions</th>
        </tr>
    </thead>
</table>

