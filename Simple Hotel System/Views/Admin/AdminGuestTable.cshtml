@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Guest Management</h3>
</div>

<table id="guestTable" class="table table-striped table-bordered w-100">
    <thead>
        <tr>
            <th>No</th>
            <th>Name</th>
            <th>Gender</th>
            <th>PhoneNum</th>
            <th>Email</th>
            <th>Action</th>
        </tr>
    </thead>
</table>

<form id="editGuestForm">
    <div class="modal fade" id="editGuestModal">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Guest</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="editId" />

                    <div class="mb-2">
                        <label>Name</label>
                        <input type="text" id="editName" class="form-control" required />
                    </div>

                    <div class="mb-2">
                        <label>Gender</label>
                        <select id="editGender" class="form-select" required>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Prefer Not To Say">Prefer Not To Say</option>
                        </select>
                    </div>

                    <div class="mb-2">
                        <label>PhoneNum</label>
                        <input type="text" id="editPhoneNum" class="form-control" required />
                    </div>

                    <div class="mb-2">
                        <label>Email</label>
                        <input type="email" id="editEmail" class="form-control" readonly />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type ="submit" class="btn btn-primary" id="btnUpdateGuest">Update</button>
                </div>
            </div>
        </div>
    </div>
</form>



@section Scripts {
    <script>
        $(document).ready(function () {
            loadTable();
        });

        function loadTable() {
            $('#guestTable').DataTable({
                ajax: {
                    url: '/Guest/GetAllGuests',
                    type: 'GET',
                    dataSrc: 'data'
                },
                columns: [
                    { data: 'no' },
                    { data: 'name' },
                    { data: 'gender' },
                    { data: 'phonenum' },
                    { data: 'email' },                   
                    {
                        data: null,
                        orderable: false,
                        render: function (data, type, row) {
                            return `
                                <button class="btn btn-sm btn-warning me-1 edit-guest"
                                    data-id="${row.id}"
                                    data-name="${row.name}"
                                    data-gender="${row.gender}"
                                    data-phonenum="${row.phonenum}"
                                    data-email="${row.email}">
                                    <i class="bi bi-pencil-square"></i>
                                </button>

                                <button class="btn btn-sm btn-danger"
                                    onclick="deleteGuest(${row.id})">
                                    <i class="bi bi-trash"></i>
                                </button>
                            `;
                        }
                    } 
                ]
            });
        }


        function deleteGuest(id) {
            if (!confirm("Are you sure you want to delete this guest?"))
                return;
            
            $.ajax({
                url: '/Guest/DeleteGuest',
                type: 'POST',
                data: { id: id },
                success: function (response) {
                    
                    if (response.success){
                        alert(response.message);
                        $('#guestTable').DataTable().ajax.reload();
                    } else{
                        alert(response.message);
                    }
                },
                error: function() {
                    alert("Something went wrong.")
                }
            });
            
        }

        $(document).on('click', '.edit-guest', function () {
            $('#editId').val($(this).data('id'));
            $('#editName').val($(this).data('name'));
            $('#editGender').val($(this).data('gender'));
            $('#editPhoneNum').val($(this).data('phonenum'));
            $('#editEmail').val($(this).data('email'));

            $('#editGuestModal').modal('show');
        });

        
        $('#btnUpdateGuest').click(function () {
            const guestName = $('#editName').val();
            if (!guestName){
                alert('Guest Name is needed');
                return;
            }

            $.ajax({
                url: '/Guest/UpdateGuest',
                type: 'POST',
                data: {
                    Id: $('#editId').val(),
                    Name: $('#editName').val(),
                    Gender: $('#editGender').val(),
                    PhoneNum: $('#editPhoneNum').val(),
                    Email: $('#editEmail').val()
                },
                success: function (response) {
                    if (response.success) {
                        alert(response.message);
                        $('#editGuestModal').modal('hide');
                        $('#guestTable').DataTable().ajax.reload();
                    } else {
                        alert(response.message);
                    }
                }
            });
        });

    </script>
}