@{
}
@model GuestInfo
<form method="post" asp-controller="Guest" asp-action="GuestForm">
    <div class="form-floating mb-3">
        <input asp-for="Name" class="form-control" placeholder="Name" required>
        <label>Name</label>
    </div>

    <div class="form-floating mb-3">
        <input asp-for="Password" type="password" class="form-control" placeholder="Password" required>
        <label>Password</label>
    </div>

    <div class="form-floating mb-3">
        <select asp-for="Gender" class="form-select" required>
            <option value="" disabled selected>Gender</option>
            <option value="1">Male</option>
            <option value="2">Female</option>
            <option value="3">Prefer Not To Say</option>
        </select>
    </div>

    <div class="form-floating mb-3">
        <input asp-for = "PhoneNum" class="form-control" placeholder="Phone Number" required>
        <label>Phone Number</label>
    </div>

    <div class="form-floating mb-3">
        <input asp-for="Email" type="email" class="form-control" placeholder="name@example.com" required>
        <label>Email address</label>
    </div>

    <button type="reset" class="btn btn-sm btn-secondary">Clear</button>
    <button type="submit" class="btn btn-sm btn-primary">Submit</button>

</form>


