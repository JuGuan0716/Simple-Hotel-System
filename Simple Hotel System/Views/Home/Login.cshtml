@{
}
@model GuestInfo
<form method="post" asp-controller="Guest" asp-action="GuestLogin">
    <div class="form-floating mb-3">
        <input asp-for="Email" type="email" class="form-control" placeholder="name@example.com" required>
        <label>Email address</label>
    </div>

    <div class="form-floating mb-3">
        <input asp-for="Password" type="password" class="form-control" placeholder="Password" required>
        <label>Password</label>
    </div> 

    <button type="reset" class="btn btn-secondary">Clear</button>
    <button type="submit" class="btn btn-primary">Login</button>


